---
// Contact.astro
---

<section id="kontakt" class="section-padding" style="background-color: #fff;">
    <div class="container">
      <div class="mx-auto max-w-3xl text-center">
  
        <!-- Eyebrow -->
        <div class="section-title text-center">
          <span class="icon-text-row wow fadeInUp">
            <img src="/assets/img/icon/contact.svg" alt="Kontakt">
            Kontakt
          </span>
          <h3 class="wow fadeInUp" data-wow-delay=".2s">Zaujala vás moje práce?</h3>
        </div>
  
        <!-- Body Text -->
        <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-gray-500 wow fadeInUp" data-wow-delay=".3s">
            Rád se s vámi spojím a probereme možnosti spolupráce.        </p>
  
        <!-- Contact Details -->
        <div class="mt-12 flex flex-col items-center justify-center gap-6 sm:flex-row sm:gap-8 wow fadeInUp" data-wow-delay=".4s">
  
          <!-- Email -->
          <a href="mailto:hello@dominikrara.cz" class="contact-link flex items-center gap-3 text-lg font-medium">
            <span class="contact-link__icon flex h-11 w-11 items-center justify-center rounded-full">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect width="20" height="16" x="2" y="4" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
            </span>
            hello@dominikrara.cz
          </a>
  
          <!-- Phone -->
          <a href="tel:+420776719717" class="contact-link flex items-center gap-3 text-lg font-medium">
            <span class="contact-link__icon flex h-11 w-11 items-center justify-center rounded-full">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.1 6.1l.9-.9a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
            </span>
            +420 776 719 717
          </a>
  
  
        </div>
      </div>
    </div>
  </section>
  
  <style>
    .contact-link {
      color: #0f0f0f;
      text-decoration: none;
      transition: color 0.2s ease;
    }
    .contact-link:hover {
      color: var(--theme, #1F7A6E);
    }
    .contact-link svg {
      color: #1F7A6E;
      transition: color 0.2s ease;
    }
    .contact-link:hover svg {
      color: var(--theme, #1F7A6E);
    }
    .contact-link__icon {
      background-color: #e8f4f2;
      transition: background-color 0.2s ease;
    }
    .contact-link:hover .contact-link__icon {
      background-color: #d0ece8;
    }
  </style>